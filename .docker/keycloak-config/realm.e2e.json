{
  "id": "e2e-testing",
  "realm": "e2e-testing",
  "displayName": "Keybound E2E",
  "displayNameHtml": "<b>Keybound</b> E2E",
  "registrationAllowed": false,
  "rememberMe": false,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": false,
  "requiredActions": [
    {
      "alias": "UPDATE_PROFILE",
      "name": "Update Profile",
      "providerId": "UPDATE_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 10
    }
  ],
  "enabled": true,
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "id": "backend-user-storage",
        "name": "backend-user-storage",
        "providerId": "backend-user-storage",
        "config": {
          "enabled": [
            "true"
          ],
          "priority": [
            "0"
          ],
          "cachePolicy": [
            "DEFAULT"
          ]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "web-mobile",
      "name": "Keybound Vite Web",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "protocolMappers": [
        {
          "name": "fineract_client_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "fineractClientId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "fineract_client_id",
            "jsonType.label": "long",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "fineract_external_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "fineractExternalId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "fineract_external_id",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "kyc-client",
      "name": "KYC Mngr",
      "surrogateAuthRequired": false,
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "some-secret",
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "authorizationServicesEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "+"
      ]
    },
    {
      "clientId": "resource-server",
      "name": "Keybound Resource Server",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [],
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "test-client",
      "name": "Postman Client Credential",
      "surrogateAuthRequired": false,
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "some-secret",
      "bearerOnly": false,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "authorizationServicesEnabled": true
    },
    {
      "clientId": "cuss-client",
      "name": "CUSS Integration Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "cuss-client-secret-12345",
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "email": "test@admin",
