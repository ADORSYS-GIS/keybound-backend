{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/flow/sessions",
    "bodyPatterns": [
      { "contains": "\"sessionType\":\"invalid\"" }
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": "Bad Request",
      "message": "Invalid session payload"
    }
  }
}
