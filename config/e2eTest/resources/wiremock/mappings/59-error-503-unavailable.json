{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/flow/sessions",
    "bodyPatterns": [
      { "contains": "\"userId\":\"unavailable-user\"" }
    ]
  },
  "response": {
    "status": 503,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": "Service Unavailable",
      "message": "Service temporarily unavailable. Please try again later."
    }
  }
}
