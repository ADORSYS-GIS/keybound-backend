{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/flow/sessions",
    "bodyPatterns": [
      { "contains": "\"userId\":\"conflict-user-id\"" }
    ]
  },
  "response": {
    "status": 409,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "error": "Conflict",
      "message": "Session already exists for this user"
    }
  }
}
