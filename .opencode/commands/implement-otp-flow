#!/bin/bash
# opencode command: implement-otp-flow
# Usage: opencode run implement-otp-flow

echo "=== Implementing Phone OTP Flow ==="

FLOW_NAME="phone_otp"
FLOW_FILE="app/crates/backend-flow-sdk/src/flows/${FLOW_NAME}.rs"

if [ -f "$FLOW_FILE" ]; then
    echo "⚠️  Flow file already exists: $FLOW_FILE"
    echo "   This will overwrite existing implementation!"
    read -p "Continue? (y/N): " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Aborted"
        exit 1
    fi
fi

echo "Creating OTP flow implementation..."

# Create the flow file
cat > "$FLOW_FILE" << 'EOF'
use async_trait::async_trait;
use backend_core::Error;
use serde_json::{Value, json};
use crate::{Step, StepContext, StepOutcome, FlowError, Actor, ContextUpdates};

pub struct IssuePhoneOtpStep;

#[async_trait]
impl Step for IssuePhoneOtpStep {
    fn step_type(&self) -> &'static str { "ISSUE_PHONE_OTP" }
    
    fn actor(&self) -> Actor { Actor::System }
    
    fn feature(&self) -> Option<&'static str> { Some("flow-phone-otp") }
    
    async fn execute(&self, ctx: &StepContext) -> Result<StepOutcome, FlowError> {
        // Extract phone from context
        let phone = ctx.flow_context["phone"]
            .as_str()
            .ok_or_else(|| FlowError::MissingField("phone"))?;
        
        // Generate 6-digit OTP
        let otp = generate_otp();
        
        // Hash OTP with Argon2
        let hash = hash_otp(&otp);
        
        // Get SMS provider from services
        let sms_provider = ctx.services
            .get::<dyn crate::integrations::SmsProvider>()
            .ok_or_else(|| FlowError::ServiceUnavailable("SmsProvider"))?;
        
        // Send OTP via SMS
        sms_provider.send_otp(phone, &otp).await
            .map_err(|e| FlowError::StepExecutionFailed(e.to_string()))?;
        
        // Store OTP hash in flow context
        let updates = ContextUpdates {
            flow_context_patch: Some(json!({
                "otp_hash": hash,
                "otp_sent_at": chrono::Utc::now()
            })),
            ..Default::default()
        };
        
        Ok(StepOutcome::Done {
            output: Some(json!({ "otp_sent": true })),
            updates: Some(updates),
        })
    }
}

pub struct VerifyPhoneOtpStep;

#[async_trait]
impl Step for VerifyPhoneOtpStep {
    fn step_type(&self) -> &'static str { "VERIFY_PHONE_OTP" }
    
    fn actor(&self) -> Actor { Actor::EndUser }
    
    fn feature(&self) -> Option<&'static str> { Some("flow-phone-otp") }
    
    async fn validate_input(&self, input: &Value) -> Result<(), FlowError> {
        let otp = input["otp"]
            .as_str()
            .ok_or_else(|| FlowError::InvalidInput("Missing otp field".into()))?;
        
        if otp.len() != 6 {
            return Err(FlowError::InvalidInput("OTP must be 6 digits".into()));
        }
        
        Ok(())
    }
    
    async fn execute(&self, ctx: &StepContext) -> Result<StepOutcome, FlowError> {
        // Get user-provided OTP
        let user_otp = ctx.input["otp"]
            .as_str()
            .ok_or_else(|| FlowError::InvalidInput("Missing otp field".into()))?;
        
        // Get stored hash from context
        let stored_hash = ctx.flow_context["otp_hash"]
            .as_str()
            .ok_or_else(|| FlowError::InvalidState("OTP not issued".into()))?;
        
        // Verify OTP with Argon2
        if verify_otp(user_otp, stored_hash) {
            // OTP correct - update session and user metadata
            let updates = ContextUpdates {
                session_context_patch: Some(json!({
                    "phone_verified": true,
                    "phone_verified_at": chrono::Utc::now()
                })),
                flow_context_patch: Some(json!({
                    "otp_verified": true
                })),
                user_metadata_patch: Some(json!({
                    "phone_verified": true,
                    "phone_verified_at": chrono::Utc::now().to_rfc3339()
                })),
                ..Default::default()
            };
            
            Ok(StepOutcome::Done {
                output: Some(json!({ "verified": true })),
                updates: Some(updates),
            })
        } else {
            // OTP incorrect - track attempts
            let attempts = ctx.flow_context["otp_attempts"]
                .as_u64()
                .unwrap_or(0) + 1;
            
            if attempts >= 3 {
                Ok(StepOutcome::Failed {
                    error: FlowError::MaxAttemptsReached,
                    retryable: false,
                })
            } else {
                let updates = ContextUpdates {
                    flow_context_patch: Some(json!({
                        "otp_attempts": attempts,
                        "last_attempt_at": chrono::Utc::now()
                    })),
                    ..Default::default()
                };
                
                Ok(StepOutcome::Failed {
                    error: FlowError::InvalidOtp,
                    retryable: true,
                })
            }
        }
    }
}

fn generate_otp() -> String {
    use rand::Rng;
    let mut rng = rand::thread_rng();
    format!("{:06}", rng.gen_range(0..1_000_000))
}

fn hash_otp(otp: &str) -> String {
    use argon2::{Argon2, PasswordHasher};
    use argon2::password_hash::SaltString;
    
    let salt = SaltString::generate(&mut rand::thread_rng());
    let argon2 = Argon2::default();
    argon2.hash_password(otp.as_bytes(), &salt)
        .map(|hash| hash.to_string())
        .unwrap_or_else(|_| panic!("Failed to hash OTP"))
}

fn verify_otp(otp: &str, hash: &str) -> bool {
    use argon2::{Argon2, PasswordVerifier};
    use argon2::password_hash::PasswordHash;
    
    let parsed_hash = match PasswordHash::new(hash) {
        Ok(h) => h,
        Err(_) => return false,
    };
    
    Argon2::default()
        .verify_password(otp.as_bytes(), &parsed_hash)
        .is_ok()
}

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_otp_generation() {
        let otp = generate_otp();
        assert_eq!(otp.len(), 6);
        assert!(otp.chars().all(|c| c.is_ascii_digit()));
    }
    
    #[test]
    fn test_otp_hashing_and_verification() {
        let otp = "123456";
        let hash = hash_otp(otp);
        assert!(verify_otp(otp, &hash));
        assert!(!verify_otp("654321", &hash));
    }
}
EOF

echo "✅ Created flow implementation: $FLOW_FILE"

# Add to registry
echo ""
echo "Updating flow registry..."
REGISTRY_FILE="app/crates/backend-server/src/flow_registry.rs"

if grep -q "flow-${FLOW_NAME}" "$REGISTRY_FILE"; then
    echo "✅ Flow already registered in $REGISTRY_FILE"
else
    # Find the phone_otp section and add after it
    sed -i '/\[cfg(feature = "flow-phone-otp")\]/a\\
#[cfg(feature = "flow-'${FLOW_NAME}'")]\n{\n    registry.register_flow(Arc::new('${FLOW_NAME}'::Flow::new()));\n    registry.register_step(Arc::new('${FLOW_NAME}'::Issue'$(echo $FLOW_NAME | sed 's/_//p' | tr '[:lower:]' '[:upper:]' | sed 's/PHONEFLOW/PHONE_OTP/')'Step));\n    registry.register_step(Arc::new('${FLOW_NAME}'::Verify'$(echo $FLOW_NAME | sed 's/_//p' | tr '[:lower:]' '[:upper:]' | sed 's/PHONEFLOW/PHONE_OTP/')'Step));\n}' "$REGISTRY_FILE"
    echo "✅ Added flow registration to $REGISTRY_FILE"
fi

# Verify compilation
echo ""
echo "Verifying compilation..."
cd app/crates/backend-server

if cargo check --features "flow-sdk,flow-${FLOW_NAME}" --quiet 2>&1 | grep -q "error"; then
    echo "❌ Compilation errors:"
    cargo check --features "flow-sdk,flow-${FLOW_NAME}" 2>&1 | grep "error" | head -5
    exit 1
else
    echo "✅ Flow compiles successfully"
fi

echo ""
echo "=== Phone OTP Flow Implementation Complete ==="
echo ""
echo "Next steps:"
echo "1. Run: opencode run test-flow phone_otp"
echo "2. Implement SMS provider trait in flow-architect"
echo "3. Run integration tests: just test-it"