#!/bin/bash
# opencode command: test-flow
# Usage: opencode run test-flow <flow-name>

FLOW_NAME=${1:-""}

if [ -z "$FLOW_NAME" ]; then
    echo "Usage: opencode run test-flow <flow-name>"
    echo "Example: opencode run test-flow phone_otp"
    exit 1
fi

echo "=== Testing Flow: $FLOW_NAME ==="

# Check if flow tests exist
TEST_FILE="app/crates/backend-flow-sdk/tests/${FLOW_NAME}.rs"
if [ ! -f "$TEST_FILE" ]; then
    echo "⚠️  No dedicated test file found: $TEST_FILE"
    echo "   Running cargo test with filter instead..."
    cd app/crates/backend-flow-sdk
    cargo test --lib ${FLOW_NAME} -- --nocapture
    exit $?
fi

echo "✅ Test file found: $TEST_FILE"

# Run flow-specific tests
echo ""
echo "Running flow tests..."
cd app/crates/backend-flow-sdk

cargo test --test ${FLOW_NAME} -- --nocapture
if [ $? -ne 0 ]; then
    echo "❌ Flow tests failed"
    exit 1
fi

echo ""
echo "Calculating coverage..."
cargo tarpaulin --test ${FLOW_NAME} --out Stdout 2>/dev/null || echo "Install tarpaulin for coverage: cargo install cargo-tarpaulin"

echo ""
echo "=== Flow Testing Complete ==="