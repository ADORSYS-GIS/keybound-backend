#!/bin/bash
# opencode command: check-workspace
# Usage: opencode run check-workspace

echo "=== Full Workspace Validation ==="

# Step 1: Format check
echo ""
echo "1. Checking code formatting..."
if ! cargo fmt --all -- --check; then
    echo "❌ Code formatting issues detected"
    echo "   Run: cargo fmt --all"
    exit 1
else
    echo "✅ Code is properly formatted"
fi

# Step 2: Clippy lints
echo ""
echo "2. Running clippy..."
if cargo clippy --all-targets --all-features -- -D warnings 2>&1 | grep -q "error"; then
    echo "❌ Clippy errors found:"
    cargo clippy --all-targets --all-features -- -D warnings 2>&1 | grep "error" | head -10
    exit 1
else
    echo "✅ No clippy warnings"
fi

# Step 3: Compilation check
echo ""
echo "3. Checking compilation..."
if ! cargo check --workspace --all-features --quiet; then
    echo "❌ Compilation errors:"
    cargo check --workspace --all-features 2>&1 | grep "error" | head -10
    exit 1
else
    echo "✅ All crates compile successfully"
fi

# Step 4: Unit tests
echo ""
echo "4. Running unit tests..."
if ! cargo test --workspace --lib --quiet; then
    echo "❌ Unit tests failed"
    cargo test --workspace --lib -- --nocapture
    exit 1
else
    echo "✅ All unit tests pass"
fi

# Step 5: Feature flag validation
echo ""
echo "5. Validating feature flags..."
cd app/crates/backend-server
feature_issues=0
for feature in flow-phone-otp flow-email-magic flow-first-deposit flow-id-document flow-address-proof; do
    if ! cargo check --features "flow-sdk,$feature" --quiet 2>&1; then
        echo "❌ Feature $feature has issues"
        ((feature_issues++))
    fi
done

if [ $feature_issues -eq 0 ]; then
    echo "✅ All flow features compile successfully"
else
    echo "❌ $feature_issues features have compilation issues"
    exit 1
fi

# Step 6: Check for uncommitted changes
echo ""
echo "6. Checking git status..."
if [ -n "$(git status --porcelain)" ]; then
    echo "⚠️  Uncommitted changes detected:"
    git status --short
else
    echo "✅ No uncommitted changes"
fi

echo ""
echo "=== Workspace Validation Complete ==="