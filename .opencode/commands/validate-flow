#!/bin/bash
# opencode command: validate-flow
# Usage: opencode run validate-flow <flow-name>

FLOW_NAME=${1:-""}

if [ -z "$FLOW_NAME" ]; then
    echo "Usage: opencode run validate-flow <flow-name>"
    echo "Example: opencode run validate-flow phone_otp"
    exit 1
fi

echo "=== Validating Flow: $FLOW_NAME ==="

# Check if flow file exists
FLOW_FILE="app/crates/backend-flow-sdk/src/flows/${FLOW_NAME}.rs"
if [ ! -f "$FLOW_FILE" ]; then
    echo "❌ Flow file not found: $FLOW_FILE"
    echo "Available flows:"
    ls app/crates/backend-flow-sdk/src/flows/*.rs | xargs -n1 basename | sed 's/.rs//'
    exit 1
fi

echo "✅ Flow file exists: $FLOW_FILE"

# Check for Step trait implementation
echo ""
echo "Checking Step trait implementation..."
if grep -q "impl Step for" "$FLOW_FILE"; then
    echo "✅ Step trait implementations found"
    grep "impl Step for" "$FLOW_FILE" | sed 's/^/   - /'
else
    echo "⚠️  No Step trait implementations found"
fi

# Check for feature flag
echo ""
echo "Checking feature flag..."
FLOW_TYPE=$(grep -h "fn flow_type" "$FLOW_FILE" 2>/dev/null | head -1 | sed "s/.*-> &'static str { \"\(.*\)\" }.*/\1/")
if [ -n "$FLOW_TYPE" ]; then
    echo "✅ Flow type: $FLOW_TYPE"
    grep -r "$FLOW_TYPE" app/crates/backend-server/Cargo.toml > /dev/null 2>&1
    if [ $? -eq 0 ]; then
        echo "✅ Feature flag configured in backend-server/Cargo.toml"
    else
        echo "❌ Feature flag NOT found in backend-server/Cargo.toml"
    fi
else
    echo "⚠️  Could not extract flow type"
fi

# Check registry registration
echo ""
echo "Checking registry registration..."
if grep -q "$FLOW_NAME" app/crates/backend-server/src/flow_registry.rs; then
    echo "✅ Flow registered in flow_registry.rs"
else
    echo "❌ Flow NOT registered in flow_registry.rs"
fi

# Check compilation
echo ""
echo "Checking compilation..."
cd app/crates/backend-server
if cargo check --features "flow-sdk,flow-${FLOW_NAME}" --quiet 2>&1 | grep -q "error"; then
    echo "❌ Compilation errors:"
    cargo check --features "flow-sdk,flow-${FLOW_NAME}" 2>&1 | grep "error" | head -5
else
    echo "✅ Compiles successfully with flow-${FLOW_NAME}"
fi

echo ""
echo "=== Flow Validation Complete ==="