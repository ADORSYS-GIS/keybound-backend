#!/bin/bash
# opencode command: daily-standup
# Usage: opencode run daily-standup

echo "=== Daily Standup for Flow SDK Project ==="
echo "Date: $(date)"
echo ""

# Check project status
echo "1. Project Status Check:"
echo "   - Git branch: $(git branch --show-current)"
echo "   - Uncommitted changes: $(git status --porcelain | wc -l) files"
echo "   - Last commit: $(git log -1 --pretty=format:'%s (%h)')"
echo ""

# Run quick compilation check
echo "2. Compilation Check:"
if cargo check --workspace --quiet 2>&1 | grep -q "error"; then
    echo "   ❌ Compilation errors found!"
    cargo check --workspace 2>&1 | grep "error" | head -5
else
    echo "   ✅ No compilation errors"
fi
echo ""

# Check test status
echo "3. Test Status:"
if cargo test --workspace --no-run --quiet 2>&1 | grep -q "error"; then
    echo "   ❌ Tests don't compile!"
else
    echo "   ✅ Tests compile successfully"
fi
echo ""

# Show feature flags status
echo "4. Feature Flags:"
cd app/crates/backend-server
cargo tree --format "{p}" --edges features -e features 2>/dev/null | grep -E "flow-|step-" | sort | uniq
echo ""

# Check TODOs and FIXMEs
echo "5. TODOs/FIXMEs:"
grep -r "TODO\|FIXME" app/crates/backend-flow-sdk/src --include="*.rs" | wc -l
echo "   TODOs/FIXMEs in flow SDK: $(grep -r "TODO\|FIXME" app/crates/backend-flow-sdk/src --include="*.rs" | wc -l)"
echo ""

echo "=== Standup Complete ==="