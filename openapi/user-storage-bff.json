{
  "openapi": "3.0.3",
  "info": {
    "title": "Customer Registration Frontend API",
    "version": "1.0.0",
    "description": "Endpoints exposed to customer-facing frontends for registration and limit status."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Example production server"
    }
  ],
  "tags": [
    {
      "name": "KYC Documents",
      "description": "Upload endpoints for customer verification documents."
    },
    {
      "name": "KYC",
      "description": "Endpoints for the customer KYC process."
    }
  ],
  "paths": {
    "/api/kyc/cases/mine": {
      "get": {
        "tags": [
          "KYC"
        ],
        "summary": "Get KYC case",
        "description": "Retrieve the current KYC case for the authenticated user.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "KYC case details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycCaseResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "KYC case not found."
          }
        }
      },
      "patch": {
        "tags": [
          "KYC"
        ],
        "summary": "Update KYC case",
        "description": "Update the KYC case with new information. Supports nested fields.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KycCasePatchRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "KYC case updated.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycCaseResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "KYC case not found."
          }
        }
      }
    },
    "/api/kyc/cases/mine/submission": {
      "post": {
        "tags": [
          "KYC"
        ],
        "summary": "Submit KYC case",
        "description": "Submit the KYC case for review. This seals the case from further edits.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "KYC case submitted.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycCaseResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "KYC case not found."
          }
        }
      }
    },
    "/api/kyc/cases/mine/documents": {
      "post": {
        "tags": [
          "KYC Documents"
        ],
        "summary": "Create a KYC document upload",
        "description": "Authenticated customers request an S3 presigned URL to upload an ID or selfie document for manual review.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/KycDocumentUploadRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Upload URL created successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycDocumentUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document type, file, or size."
          },
          "401": {
            "description": "Unauthorized."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/limits": {
      "get": {
        "tags": [
          "KYC"
        ],
        "summary": "Get transaction limits",
        "description": "Retrieve deposit/withdrawal limits based on the customer's KYC tier.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Limits and usage details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "KycDocumentUploadRequest": {
        "type": "object",
        "required": [
          "documentType",
          "fileName",
          "mimeType",
          "contentLength"
        ],
        "properties": {
          "documentType": {
            "type": "string",
            "description": "One of id_front, id_back, selfie_with_id."
          },
          "fileName": {
            "type": "string"
          },
          "mimeType": {
            "type": "string",
            "description": "File MIME type (e.g., image/jpeg)."
          },
          "contentLength": {
            "type": "integer",
            "format": "int64",
            "description": "Expected file size in bytes."
          }
        }
      },
      "KycDocumentUploadResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "documentType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "fileName": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          },
          "uploadUrl": {
            "type": "string",
            "format": "uri",
            "description": "Presigned S3 URL for direct upload."
          },
          "uploadMethod": {
            "type": "string",
            "description": "HTTP method to use when uploading to uploadUrl."
          },
          "uploadHeaders": {
            "type": "object",
            "description": "Headers that must be sent during upload.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "When the presigned URL expires."
          },
          "s3Bucket": {
            "type": "string"
          },
          "s3Key": {
            "type": "string"
          }
        }
      },
      "KycCaseResponse": {
        "type": "object",
        "properties": {
          "caseId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "OPEN",
              "SUBMITTED",
              "IN_REVIEW",
              "APPROVED",
              "REJECTED",
              "MORE_INFO_NEEDED"
            ]
          },
          "userProfile": {
            "$ref": "#/components/schemas/UserProfile"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KycDocument"
            }
          },
          "comments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/StaffComment"
            }
          }
        }
      },
      "KycCasePatchRequest": {
        "type": "object",
        "properties": {
          "userProfile": {
            "$ref": "#/components/schemas/UserProfile"
          }
        }
      },
      "UserProfile": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "nationality": {
            "type": "string"
          },
          "address": {
            "$ref": "#/components/schemas/Address"
          }
        }
      },
      "Address": {
        "type": "object",
        "properties": {
          "street": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "postalCode": {
            "type": "string"
          },
          "country": {
            "type": "string"
          }
        }
      },
      "KycDocument": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "documentType": {
            "type": "string"
          },
          "fileName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "StaffComment": {
        "type": "object",
        "properties": {
          "commentId": {
            "type": "string"
          },
          "staffId": {
            "type": "string"
          },
          "comment": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "LimitsResponse": {
        "type": "object",
        "properties": {
          "kycTier": {
            "type": "integer"
          },
          "tierName": {
            "type": "string"
          },
          "limits": {
            "$ref": "#/components/schemas/LimitsResponseLimitsDto"
          },
          "usage": {
            "$ref": "#/components/schemas/LimitsResponseUsageDto"
          },
          "available": {
            "$ref": "#/components/schemas/LimitsResponseAvailableDto"
          },
          "allowedPaymentMethods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restrictedFeatures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "LimitsResponseLimitsDto": {
        "type": "object",
        "properties": {
          "dailyDepositLimit": {
            "type": "number"
          },
          "dailyWithdrawalLimit": {
            "type": "number"
          },
          "perTransactionLimit": {
            "type": "number"
          },
          "monthlyTransactionLimit": {
            "type": "number"
          }
        }
      },
      "LimitsResponseUsageDto": {
        "type": "object",
        "properties": {
          "dailyDepositUsed": {
            "type": "number"
          },
          "dailyWithdrawalUsed": {
            "type": "number"
          },
          "monthlyUsed": {
            "type": "number"
          }
        }
      },
      "LimitsResponseAvailableDto": {
        "type": "object",
        "properties": {
          "depositRemaining": {
            "type": "number"
          },
          "withdrawalRemaining": {
            "type": "number"
          }
        }
      }
    }
  }
}
