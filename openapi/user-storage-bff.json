{
  "openapi": "3.0.3",
  "info": {
    "title": "Customer Registration Frontend API",
    "version": "1.0.0",
    "description": "Endpoints exposed to customer-facing frontends for registration and limit status."
  },
  "servers": [
    {
      "url": "https://api.example.com",
      "description": "Example production server"
    }
  ],
  "tags": [
    {
      "name": "KYC Documents",
      "description": "Upload endpoints for customer verification documents."
    },
    {
      "name": "Registration",
      "description": "Endpoints exposed for customer self-registration and status inquiry."
    }
  ],
  "paths": {
    "/api/registration/kyc/documents": {
      "post": {
        "tags": [
          "KYC Documents"
        ],
        "summary": "Upload a KYC document",
        "description": "Authenticated customers can upload ID or selfie documents for manual review.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-External-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Optional external ID to use when JWT does not carry the claim (local testing)."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "documentType",
                  "file"
                ],
                "properties": {
                  "documentType": {
                    "type": "string",
                    "description": "One of id_front, id_back, selfie_with_id."
                  },
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Image file in JPEG, PNG, or WebP with max size 10MB."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Document uploaded successfully.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycDocumentUploadResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid document type, file, or size."
          },
          "401": {
            "description": "Unauthorized."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      }
    },
    "/api/registration/kyc/status": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Get KYC status",
        "description": "Retrieve the KYC verification status and document metadata.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-External-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "External ID (JWT usually carries it)."
          }
        ],
        "responses": {
          "200": {
            "description": "KYC status information.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KycStatusResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    },
    "/api/registration/limits": {
      "get": {
        "tags": [
          "Registration"
        ],
        "summary": "Get transaction limits",
        "description": "Retrieve deposit/withdrawal limits based on the customer's KYC tier.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "X-External-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "External ID (JWT usually carries it)."
          }
        ],
        "responses": {
          "200": {
            "description": "Limits and usage details.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LimitsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized."
          },
          "404": {
            "description": "Customer not found."
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "KycDocumentUploadResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string"
          },
          "documentType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "fileName": {
            "type": "string"
          },
          "mimeType": {
            "type": "string"
          }
        }
      },
      "KycStatusResponse": {
        "type": "object",
        "properties": {
          "kycTier": {
            "type": "integer"
          },
          "kycStatus": {
            "type": "string"
          },
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KycStatusResponseDocumentStatus"
            }
          },
          "requiredDocuments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "missingDocuments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "KycStatusResponseDocumentStatus": {
        "type": "object",
        "properties": {
          "documentType": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "uploadedAt": {
            "type": "string",
            "format": "date-time"
          },
          "rejectionReason": {
            "type": "string"
          }
        }
      },
      "LimitsResponse": {
        "type": "object",
        "properties": {
          "kycTier": {
            "type": "integer"
          },
          "tierName": {
            "type": "string"
          },
          "limits": {
            "$ref": "#/components/schemas/LimitsResponseLimitsDto"
          },
          "usage": {
            "$ref": "#/components/schemas/LimitsResponseUsageDto"
          },
          "available": {
            "$ref": "#/components/schemas/LimitsResponseAvailableDto"
          },
          "allowedPaymentMethods": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "restrictedFeatures": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "currency": {
            "type": "string"
          }
        }
      },
      "LimitsResponseLimitsDto": {
        "type": "object",
        "properties": {
          "dailyDepositLimit": {
            "type": "number"
          },
          "dailyWithdrawalLimit": {
            "type": "number"
          },
          "perTransactionLimit": {
            "type": "number"
          },
          "monthlyTransactionLimit": {
            "type": "number"
          }
        }
      },
      "LimitsResponseUsageDto": {
        "type": "object",
        "properties": {
          "dailyDepositUsed": {
            "type": "number"
          },
          "dailyWithdrawalUsed": {
            "type": "number"
          },
          "monthlyUsed": {
            "type": "number"
          }
        }
      },
      "LimitsResponseAvailableDto": {
        "type": "object",
        "properties": {
          "depositRemaining": {
            "type": "number"
          },
          "withdrawalRemaining": {
            "type": "number"
          }
        }
      }
    }
  }
}
